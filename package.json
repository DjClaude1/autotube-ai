{
  "name": "autotube-ai",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered system that generates full YouTube videos from a topic input.",
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:server dev:worker",
    "dev:web": "npm run dev --workspace web",
    "dev:server": "npm run dev --workspace server",
    "dev:worker": "npm run worker:dev --workspace server",
    "build": "npm run build --workspace server && npm run build --workspace web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
