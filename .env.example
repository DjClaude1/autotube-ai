# -----------------------------------------------------------------------------
# AutoTube AI ‚Äî environment variables
# Copy to `.env` in the repo root and fill in values. `web` and `server` each
# read from their own `.env.local` / `.env` as well (see their directories).
# -----------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=autotube-videos

# Exposed to the Next.js client (must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# --- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- ElevenLabs ------------------------------------------------------------
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- Redis (BullMQ) --------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Stripe ----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Comma-separated "price_id:credits" pairs (create these in Stripe Dashboard)
STRIPE_CREDIT_PACKS=price_10:10,price_50:55,price_200:240
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- URLs ------------------------------------------------------------------
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=${API_URL}
WEB_URL=http://localhost:3000

# --- Server config ---------------------------------------------------------
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Free credits granted to every new user on first login
FREE_SIGNUP_CREDITS=2

# --- FFmpeg / rendering ----------------------------------------------------
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
RENDER_WIDTH=1080
RENDER_HEIGHT=1920
RENDER_FPS=30
WORK_DIR=./work
